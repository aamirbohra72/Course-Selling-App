NODE_ENV=development
PORT=3000
# If 3000 is taken (Docker, other Node apps), use e.g. 3001 and match CORS_ORIGIN.

# Neon: Connection details → URI (pooled). Use sslmode=require.
# If Neon adds channel_binding=require, omit it for node-pg or use Neon’s Node docs.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Min 32 characters when NODE_ENV=production
JWT_SECRET=change-me-to-a-long-random-secret-in-production-at-least-32-chars

# Comma-separated allowed browser origins. In production, if unset, cross-origin API access is denied (same-origin UI still works).
CORS_ORIGIN=http://localhost:3000

# Admin self-signup: in production defaults to off unless set to true
ADMIN_SIGNUP_ENABLED=true

# Optional
# PG_POOL_MAX=20
# PG_CONNECT_TIMEOUT_MS=15000
# DATABASE_SSL=false
